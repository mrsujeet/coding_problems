/*
https://leetcode.com/problems/top-k-frequent-words/
Given an array of strings words and an integer k, return the k most frequent strings.

Return the answer sorted by the frequency from highest to lowest. Sort the words with the same frequency by their lexicographical order.

 

Example 1:

Input: words = ["i","love","leetcode","i","love","coding"], k = 2
Output: ["i","love"]
Explanation: "i" and "love" are the two most frequent words.
Note that "i" comes before "love" due to a lower alphabetical order.
Example 2:

Input: words = ["the","day","is","sunny","the","the","the","sunny","is","is"], k = 4
Output: ["the","is","sunny","day"]
Explanation: "the", "is", "sunny" and "day" are the four most frequent words, with the number of occurrence being 4, 3, 2 and 1 respectively.
 

Constraints:

1 <= words.length <= 500
1 <= words[i].length <= 10
words[i] consists of lowercase English letters.
k is in the range [1, The number of unique words[i]]
 

Follow-up: Could you solve it in O(n log(k)) time and O(n) extra space?


*/

/*
Time:  O(n log k)
Space: O(n)
*/

import java.util.*;

class Solution {
    public List<String> topKFrequent(String[] words, int k) {
        Map<String, Integer> freq = new HashMap<>();

        // Count frequency of each word
        for (String word : words) {
            freq.put(word, freq.getOrDefault(word, 0) + 1);
        }

        /*
         Min heap of size k.

         Heap top should contain the "worst" word:
         1. Lower frequency is worse
         2. If frequency is same, lexicographically larger word is worse
        */
        PriorityQueue<String> pq = new PriorityQueue<>(
            (word1, word2) -> {
                int freq1 = freq.get(word1);
                int freq2 = freq.get(word2);

                // Lower frequency should come first in min heap
                if (freq1 != freq2) {
                    return freq1 - freq2;
                }

                // For same frequency, lexicographically larger word is worse,
                // so we reverse alphabetical order.
                return word2.compareTo(word1);
            }
        );

        // Add only unique words to heap
        for (String word : freq.keySet()) {
            pq.offer(word);

            // Remove worst word if heap size becomes more than k
            if (pq.size() > k) {
                pq.poll();
            }
        }

        List<String> list = new ArrayList<>();

        // Heap gives words from worst to best
        while (!pq.isEmpty()) {
            list.add(pq.poll());
        }

        // Reverse to get best to worst
        Collections.reverse(list);

        return list;
    }
}
