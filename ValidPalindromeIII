class Solution {
   //method 1: Version with Memoization

    public boolean isValidPalindrome(String s, int k) {
        Map<String, Boolean> memo= new HashMap<>();
        return helper(s,k,memo,0,s.length()-1);

    }

    private boolean helper(String s, int k, Map<String,Boolean> memo,int l, int r){
        if(l>=r) return true;

        String key=l+","+r+","+k;

        if(memo.containsKey(key)) return memo.get(key);

        if(s.charAt(l)==s.charAt(r)){
            memo.put(key,helper(s,k,memo,l+1,r-1));
        }
        else if(k==0) return false;

        else{
            memo.put(key,helper(s,k-1,memo,l+1,r)|| helper(s,k-1,memo,l,r-1));
        }

        return memo.get(key);

    }

