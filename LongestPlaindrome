/*
https://leetcode.com/problems/longest-palindromic-substring/description/
https://leetcode.com/explore/interview/card/facebook/55/dynamic-programming-3/3034/


Given a string s, return the longest palindromic substring in s.

 

Example 1:

Input: s = "babad"
Output: "bab"
Explanation: "aba" is also a valid answer.
Example 2:

Input: s = "cbbd"
Output: "bb"
 

Constraints:

1 <= s.length <= 1000
s consist of only digits and English letters.

*/





    String maxStr="";

    public String longestPalindrome(String s) {
     
        for(int i=0; i<s.length(); i++){

            expand(s, i, i); // odd length palindrom
            expand(s,i, i+1);  //even length. palindrom

        }
        return maxStr;
    }
        private void expand(String s, int l, int r){

            while(l>=0 && r<s.length()){
                    if(s.charAt(l)!=s.charAt(r)){
                        return;
                }
                maxStr=maxStr.length()<=(r-l+1)?s.substring(l,r+1):maxStr;
                l--;
                r++;
            }

        }
        
    
