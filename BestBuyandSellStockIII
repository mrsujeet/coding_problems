/*
https://leetcode.com/problems/best-time-to-buy-and-sell-stock-iii/description/?envType=company&envId=facebook&favoriteSlug=facebook-thirty-days

You are given an array prices where prices[i] is the price of a given stock on the ith day.

Find the maximum profit you can achieve. You may complete at most two transactions.

Note: You may not engage in multiple transactions simultaneously (i.e., you must sell the stock before you buy again).

 

Example 1:

Input: prices = [3,3,5,0,0,3,1,4]
Output: 6
Explanation: Buy on day 4 (price = 0) and sell on day 6 (price = 3), profit = 3-0 = 3.
Then buy on day 7 (price = 1) and sell on day 8 (price = 4), profit = 4-1 = 3.
Example 2:

Input: prices = [1,2,3,4,5]
Output: 4
Explanation: Buy on day 1 (price = 1) and sell on day 5 (price = 5), profit = 5-1 = 4.
Note that you cannot buy on day 1, buy on day 2 and sell them later, as you are engaging multiple transactions at the same time. You must sell before buying again.
Example 3:

Input: prices = [7,6,4,3,1]
Output: 0
Explanation: In this case, no transaction is done, i.e. max profit = 0.
 

Constraints:

1 <= prices.length <= 105
0 <= prices[i] <= 105

*/



public class Solution {
    public int maxProfit(int[] prices) {
        if (prices == null || prices.length < 2) return 0;

        // These track max profit at each stage:
        // Simulate: Buy1 → Sell1 → Buy2 → Sell2

        int firstBuyProfit = Integer.MIN_VALUE;   // Max profit after first buy (negative)
        int firstSellProfit = 0;                  // Max profit after first sell
        int secondBuyProfit = Integer.MIN_VALUE;  // Max profit after second buy (after Sell1)
        int secondSellProfit = 0;                 // Max profit after second sell (final answer)

        for (int price : prices) {

            // 1️⃣ First Buy: Choose the lowest price to buy
            // Want to "spend the least", so we store the most negative value
            firstBuyProfit = Math.max(firstBuyProfit, -price);

            // 2️⃣ First Sell: Maximize profit from selling after first buy
            // Example: firstBuyProfit = -3, price = 5 ⇒ firstSellProfit = 2
            firstSellProfit = Math.max(firstSellProfit, firstBuyProfit + price);

            // 3️⃣ Second Buy: Use profit from first sell to "buy again"
            // Think of it as: remaining money after first profit - current price
            // Example: firstSellProfit = 3, price = 1 ⇒ secondBuyProfit = 2
            secondBuyProfit = Math.max(secondBuyProfit, firstSellProfit - price);

            // 4️⃣ Second Sell: Sell the second stock and maximize final profit
            // secondBuyProfit represents profit left after second buy
            // If we sell today, total profit = secondBuyProfit + today's price
            //
            // Example:
            //    secondBuyProfit = 2 (we bought second stock at price=1 after earning 3),
            //    today's price = 4 → total = 2 + 4 = 6
            secondSellProfit = Math.max(secondSellProfit, secondBuyProfit + price);
        }

        // Final result is the best total profit after at most two transactions
        return secondSellProfit;
    }
}
