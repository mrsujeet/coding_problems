public long kMirror(int k, int n) {
        int count = 0;
        long sum = 0;
        int length = 1;
        /*
        1) first requirement decimal plaindrome
        2) second requirement base k number is palindrome
        */

        //first check odd length and then even length, because even digit comes after odd digit
        while (count < n) {
            // Generate odd-length base-10 palindromes
            for (int half = (int) Math.pow(10, length - 1); half < Math.pow(10, length); half++) {// ie 1 digit
                String s = String.valueOf(half);

               /* This guarantees the number is already a odd length decimal palindrome (first requirement)
                s = "123"
                sb = "21"
                palStr = "12321" (odd-length palindrome)
                */

                StringBuilder sb = new StringBuilder(s).deleteCharAt(s.length() - 1).reverse();
                String palStr = s + sb.toString();
                long pal = Long.parseLong(palStr);

                if (isKPalindrome(pal, k)) {
                    sum += pal;
                    count++;
                    if (count == n) return sum;
                }
            }

            // Generate even-length base-10 palindromes
            for (int half = (int) Math.pow(10, length - 1); half < Math.pow(10, length); half++) { //i.e 2 digit
                    String s = String.valueOf(half);
                    /* This guarantees the number is already a even length decimal palindrome (first requirement)*/
                    StringBuilder sb = new StringBuilder(s).reverse();
                    String palStr = s + sb.toString();
                    long pal = Long.parseLong(palStr);

                if (isKPalindrome(pal, k)) {
                    sum += pal;
                    count++;
                    if (count == n) return sum;
                }
            }

            length++;
        }

        return sum;
    }

    // Helper to check if number is a palindrome in base-k
    private boolean isKPalindrome(long num, int k) {
        String baseK = toBaseK(num, k);
        return isPalindrome(baseK);
    }

    // Convert number to base-k string
    private String toBaseK(long num, int k) {
        StringBuilder sb = new StringBuilder();
        while (num > 0) {
            sb.append(num % k);
            num /= k;
        }
        return sb.reverse().toString();
    }

    // Check if a string is a palindrome
    private boolean isPalindrome(String s) {
        int l = 0, r = s.length() - 1;
        while (l < r) {
            if (s.charAt(l++) != s.charAt(r--)) return false;
        }
        return true;
    }


