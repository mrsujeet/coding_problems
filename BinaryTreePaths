/*

https://leetcode.com/problems/binary-tree-paths/description/

Given the root of a binary tree, return all root-to-leaf paths in any order.

A leaf is a node with no children.

 

Example 1:


Input: root = [1,2,3,null,5]
Output: ["1->2->5","1->3"]
Example 2:

Input: root = [1]
Output: ["1"]
 

Constraints:

The number of nodes in the tree is in the range [1, 100].
-100 <= Node.val <= 100


*/




 public List<String> binaryTreePaths(TreeNode root) {
        List<String> paths = new ArrayList<>();
        if(root==null) return paths;
        
        helper(paths,"",root);
        return paths;
    }
    
    void helper(List<String> paths,String path, TreeNode root){
        
        if(root==null) return;
        
        /*
cur is a new String for each call (Strings are immutable). Each recursive frame has its own copy, so when a path finishes, nothing needs to be “removed”—the older frames still have their own cur. When recursion returns, that local cur just goes out of scope.
        
        */
        
        String curr = path.isEmpty() ? Integer.toString(root.val) : path+"->"+root.val;
        
        //each path should have root node before its children node
        if(root.left==null && root.right==null){
            paths.add(curr);
        }
        
        if(root.left!=null){
             helper(paths,curr,root.left);
        }
        
        if(root.right!=null){
             helper(paths,curr,root.right);
        }
        
    }


/*
Complexity

Time: O(n * L) — visit each node once; building strings costs up to path length L per node.

Space: O(h * L) — recursion stack up to tree height h, plus path string overhead.
*/








































































































































































